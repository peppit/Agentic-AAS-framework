$type($) = "object" ? (
  $val := $exists(isRunning) ? isRunning :
    $exists(boxDetected) ? boxDetected :
    $exists(isMoving) ? isMoving :
    $exists(currentSpeed) ? currentSpeed :
    $exists(value) ? value : $;

  $type($val) = "string" ? (
    $s := $lowercase($trim($val));
    $s = "true" ? true :
    $s = "false" ? false : $number($val)
  ) : $val
) : $