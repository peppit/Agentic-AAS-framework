$type($) = "object" ? (
    $exists(isRunning) ? (
        $type(isRunning) = "string" ? ($lowercase(isRunning) = "true") : $boolean(isRunning)
    ) : 
    $exists(boxDetected) ? (
        $type(boxDetected) = "string" ? ($lowercase(boxDetected) = "true") : $boolean(boxDetected)
    ) : 
    $exists(isMoving) ? (
        $type(isMoving) = "string" ? ($lowercase(isMoving) = "true") : $boolean(isMoving)
    ) : 
    $exists(currentSpeed) ? $number(currentSpeed) :
    $exists(value) ? (
        $type(value) = "string" ? (
            $lowercase(value) = "true" ? true :
            $lowercase(value) = "false" ? false : $number(value)
        ) : value
    ) : $
) : $